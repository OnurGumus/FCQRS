<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <!-- override the repo Directory.Build.props (docs are for the library, not this test) -->
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Tests.fs" />
  </ItemGroup>

  <!-- Smoke-tests the FCQRS.FSharp facade end to end against the current source. -->
  <ItemGroup>
    <ProjectReference Include="..\..\src\FCQRS\FCQRS.fsproj" />
    <ProjectReference Include="..\..\src\FCQRS.Model\FCQRS.Model.fsproj" />
    <PackageReference Include="Expecto" Version="10.*" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.*" />
  </ItemGroup>

</Project>
